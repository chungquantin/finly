# LLM Providers
# Finly agents default runtime uses OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: OpenAI direct (for voice/TTS fallback)
OPENAI_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# API server runtime
FINLY_AGENTS_HOST=0.0.0.0
FINLY_AGENTS_PORT=8000

# LLM model selection
FINLY_AGENT_MODEL=openai/gpt-4.1-mini
FINLY_INTAKE_MODEL=openai/gpt-4.1-mini
FINLY_PANEL_MODEL=openai/gpt-4.1-mini
FINLY_MEMORY_MODEL=openai/gpt-4.1-mini

# Default ticker
FINLY_DEFAULT_TICKER=FPT

# Data vendors (default: yfinance)
FINLY_VENDOR_CORE_STOCK=yfinance
FINLY_VENDOR_TECHNICAL=yfinance
FINLY_VENDOR_FUNDAMENTAL=yfinance
FINLY_VENDOR_NEWS=yfinance

# Debate tuning
FINLY_MAX_DEBATE_ROUNDS=1
FINLY_MAX_RISK_ROUNDS=1

# Database
FINLY_DB_PATH=
